{
  "framework": "nextjs",
  "buildCommand": "rm -rf .next && npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/nightly-refresh",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/ghl-opportunities-reconcile",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/ghl-opportunities-reconcile?full=true",
      "schedule": "0 3 * * *"
    }
  ]
}
