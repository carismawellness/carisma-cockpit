/* ══════════════════════════════════════════════════════════════════════════════
   MARKETING DASHBOARD — Expert Panel Benchmarks
   Applies to: /marketing, /marketing/spa, /marketing/aesthetics, /marketing/slimming

   Paid media benchmarks: Meta SMB wellness vertical, WordStream Healthcare paid
   search, Carisma unit economics (kpi_thresholds.json — Spa CPL target €8/kill
   €16; Aesthetics CPL target €12/kill €24; Slimming ~€9.20 blended at 0.92 FX).
   Attribution note: ROAS = platform-attributed (leads × avg_deal_value / spend).
   Cash-adjusted ROAS ≈ platform × show_rate (0.80–0.85). Use platform thresholds
   consistently throughout the engine — do not compare to cash ROAS.
   Email benchmarks: Klaviyo 2024 Health & Wellness Industry Report.
   ══════════════════════════════════════════════════════════════════════════════ */

/* ── Marketing RAG Thresholds ───────────────────────────────────────────────
   Same convention as OPS:
     higher_better: green >= .green, yellow >= .yellow, red < .yellow
     lower_better:  green <= .green, yellow <= .yellow, red > .yellow
   ─────────────────────────────────────────────────────────────────────────── */

export const MKT_RAG_THRESHOLDS = {
  // Blended ROAS (Meta + Google combined; platform-attributed)
  // Carisma unit economics: implied ROAS at CPL target = ~6–9x per brand
  // Green ≥ 6.0 = profitable after show-rate haircut (÷0.85 = ~5.1x cash)
  // Red < 3.5 = likely cash-negative on first appointment
  roas:              { green: 6.0,  yellow: 3.5,  direction: "higher_better" as const },

  // CPL (Meta) — blended portfolio (budget-weighted target ≈ €9.65)
  cplBlended:        { green: 10,   yellow: 18,   direction: "lower_better" as const },

  // CPL (Meta) — per brand (from kpi_thresholds.json; yellow = 1.5× target)
  cplSpa:            { green: 8,    yellow: 12,   direction: "lower_better" as const },
  cplAesthetics:     { green: 12,   yellow: 18,   direction: "lower_better" as const },
  cplSlimming:       { green: 9.20, yellow: 13.80, direction: "lower_better" as const },

  // CPC — Google Ads (Malta low-competition: €0.60–€2.50 typical range)
  // Red > 2.00 → implied CPL > €50 at 4% conv rate, exceeds every brand's target
  cpc:               { green: 1.20, yellow: 2.00, direction: "lower_better" as const },

  // % Healthy campaigns (1 − fatigue%). Malta audience saturates fast.
  // Red < 40 = majority of spend into fatigued creative → CPL rising structurally
  fatigueHealthyPct: { green: 70,   yellow: 40,   direction: "higher_better" as const },

  // Email open rate — Klaviyo 2024 Health & Wellness industry average: 21.5%
  emailOpenRate:     { green: 25,   yellow: 20,   direction: "higher_better" as const },

  // Email click rate — Klaviyo 2024 H&W average: 2.3%
  emailClickRate:    { green: 3.5,  yellow: 2.3,  direction: "higher_better" as const },
} as const;

/* ── Kill Thresholds (from kpi_thresholds.json — used in action copy only) ── */

export const MKT_KILL_THRESHOLDS = {
  cplSpa: 16,
  cplAesthetics: 24,
  cplSlimming: 18.40,
  roasMin: 2.0,     // below this → pause recommendation at campaign level
};

